# === Cấu hình cơ bản ===
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Hosts / CSRF
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# === Cấu hình Database ===
# Ưu tiên DATABASE_URL nếu có (ví dụ MySQL):
# DATABASE_URL=mysql://root:password@localhost:3306/eduresource
DATABASE_URL=

# Fallback MySQL params khi không dùng DATABASE_URL
DB_NAME=eduresource
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_CONN_MAX_AGE=600

# === AI ===
GROQ_API_KEY=

# === Cache / Static ===
CACHE_TIMEOUT=300
CACHE_MAX_ENTRIES=1000
CACHE_KEY_PREFIX=eduresource
WHITENOISE_MAX_AGE=0

# === Upload ===
DATA_UPLOAD_MAX_NUMBER_FIELDS=2000
# Lưu nội dung file upload vào DB (fallback an toàn khi deploy, ví dụ Vercel)
STORE_UPLOADS_IN_DB=False

# === Auth / Password ===
PASSWORD_MIN_LENGTH=8

# === Cookie / Security ===
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Bật khi chạy production qua HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
