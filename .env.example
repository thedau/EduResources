# === Cấu hình EduResource ===
# Khóa bí mật Django - thay đổi trong môi trường production
SECRET_KEY=your-secret-key-change-in-production
# API Key cho Gemini AI - lấy từ https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Chế độ debug - đặt False trong production
DEBUG=True

# Host được phép truy cập
ALLOWED_HOSTS=*

# === Cấu hình Database ===
# Sử dụng SQLite (mặc định)
DB_ENGINE=django.db.backends.sqlite3

# Để sử dụng MySQL, đổi DB_ENGINE thành:
# DB_ENGINE=django.db.backends.mysql
DB_NAME=eduresource
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
